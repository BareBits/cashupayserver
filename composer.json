{
    "name": "barebits/cashupayserver",
    "description": "BTCPay-compatible Lightning payment gateway with on-chain Bitcoin support",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.0",
        "bitwasp/bitcoin": "^1.1",
        "phpmailer/phpmailer": "^6.9",
        "swentel/nostr-php": "^1.9"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {}
    }
}
